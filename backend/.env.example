# Copy this file to .env and update values as needed for local development

# Postgres connection used by Prisma and the app
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/moodsense"

# Server
PORT=5000

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5173

# Optional: other env-vars used by the app (JWT secrets, etc.)
# JWT_ACCESS_SECRET=change-me
# JWT_REFRESH_SECRET=change-me